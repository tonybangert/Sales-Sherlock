# Required: get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Apollo.io enrichment (firmographics + person match)
# Sign up at https://www.apollo.io — the free tier is enough to try Sherlock
APOLLO_API_KEY=

# Optional: override the Claude model (default: claude-sonnet-4-6)
# Other options: claude-opus-4-6 (slower, more expensive, sharper)
#                claude-haiku-4-5-20251001 (fastest, cheapest, less depth)
SHERLOCK_MODEL=claude-sonnet-4-6

# Optional: max tokens per brief section (default: 1500)
SHERLOCK_MAX_TOKENS=1500

# Optional: directory of prompt overrides
# See README.md > Customizing prompts
# SHERLOCK_PROMPTS_DIR=/path/to/your/prompts
